{
  "name": "@latenciatech/prism",
  "version": "1.0.0",
  "description": "AI-powered project auditor — static analysis + LLM intelligence",
  "type": "module",
  "bin": {
    "prism": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format esm --dts --clean --outDir dist/cli && tsup src/core/engine.ts --format esm --dts --clean --outDir dist/core",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "audit": "tsx src/cli/index.ts analyze .",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.103.0",
    "adm-zip": "^0.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "ignore": "^6.0.2",
    "ora": "^8.1.0",
    "table": "^6.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "LatenciaTech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/picaro10/prism.git"
  },
  "bugs": {
    "url": "https://github.com/picaro10/prism/issues"
  },
  "homepage": "https://github.com/picaro10/prism#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/core/engine.js",
  "types": "./dist/core/engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/engine.d.ts",
      "import": "./dist/core/engine.js"
    }
  },
  "keywords": [
    "audit",
    "code-quality",
    "static-analysis",
    "security",
    "ai",
    "llm",
    "cli",
    "linter",
    "code-review"
  ],
  "publishConfig": {
    "access": "public"
  }
}
